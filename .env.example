NODE_ENV=development
PORT=3004

# Wire these as features land (see architecture/06, 03, 08).
# Sandbox Service is Mongo-only (mongo.cuckoo_reports collection per
# arch §2) — no Postgres schema, no DATABASE_URL.
MONGODB_URI=mongodb://localhost:27017/mis_sandbox?directConnection=true
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:29092
AUTH_JWKS_URI=http://localhost:3001/.well-known/jwks.json
LOG_LEVEL=debug

# Cuckoo REST API. Profile-gated container in mis-dev (needs /dev/kvm).
# Leave unset to use the in-process deterministic mock — see
# architecture/document-upload-workflow.md §6.2.
# CUCKOO_URL=http://localhost:8090
